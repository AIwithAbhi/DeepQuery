# FILE: .env.example
# NVIDIA API Key - Get from https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here

# Brave Search API Key - Get from https://brave.com/search/api/
BRAVE_API_KEY=your_brave_api_key_here

# Optional: Database file path (defaults to research_data.db)
DB_PATH=research_data.db
